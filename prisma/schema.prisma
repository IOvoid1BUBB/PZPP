generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  KREATOR
  UCZESTNIK
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

enum OAuthProvider {
  GOOGLE
  JIRA
}

enum IntegrationConnectionStatus {
  CONNECTED
  ERROR
  REVOKED
  DISCONNECTED
}

model User {
  id                      String    @id @default(cuid())
  name                    String?
  email                   String?   @unique
  password                String? // Pole na zahashowane hasło
  timezone                String?   @default("Europe/Warsaw")
  emailVerified           DateTime?
  image                   String?
  role                    Role      @default(UCZESTNIK)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  jiraSelectedProjectKey  String?
  jiraSelectedProjectName String?
  jiraSelectedCloudId     String?

  accounts           Account[]
  sessions           Session[]
  apiKeyIntegrations ApiKeyIntegration[]
  oauthStates        OAuthState[]
  oauthIntegrations  OAuthIntegration[]

  // Relacje biznesowe
  organizedMeetings Meeting[]     @relation("MeetingOrganizer")
  tasks             Task[]
  enrollments       Enrollment[]
  certificates      Certificate[]
  lessonNotes       StudentLessonNote[]
  lessonQuestionsAuthored LessonQuestion[] @relation("LessonQuestionAuthor")
  landingPages      LandingPage[]
  ownedLeads        Lead[]             @relation("LeadOwner")
  tags              Tag[]              @relation("TagOwner")
  courses           Course[]
  funnels           Funnel[]           @relation("FunnelOwner")
  orders            Order[]
  ownedDeals        Deal[]             @relation("DealOwner")
  automationRules   AutomationRule[]   @relation("AutomationOwner")
  assignedMessages  Message[]          @relation("MessageAssignee")
  internalComments  InternalComment[]  @relation("InternalCommentAuthor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ApiKeyIntegration {
  id           String   @id @default(cuid())
  userId       String
  providerName String
  encryptedKey String   @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerName])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthState {
  id        String        @id @default(cuid())
  userId    String
  provider  OAuthProvider
  stateHash String
  nonceHash String?
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, stateHash])
  @@index([userId, provider])
  @@index([expiresAt])
}

model OAuthIntegration {
  id                    String                      @id @default(cuid())
  ownerId               String
  provider              OAuthProvider
  externalAccountId     String?
  externalEmail         String?
  jiraCloudId           String?
  jiraSiteUrl           String?
  scopes                String?
  encryptedAccessToken  String                      @db.Text
  encryptedRefreshToken String?                     @db.Text
  accessTokenExpiresAt  DateTime?
  status                IntegrationConnectionStatus @default(CONNECTED)
  lastSyncedAt          DateTime?
  calendarLastSyncedAt  DateTime?
  contactsLastSyncedAt  DateTime?
  ticketsLastSyncedAt   DateTime?
  lastError             String?                     @db.Text
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, provider])
  @@index([ownerId, status])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//MODUŁ A & B: CRM, LEADY, LEJKI SPRZEDAŻY

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum FunnelStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FunnelStepType {
  LANDING
  CHECKOUT
  THANK_YOU
  CUSTOM
}

enum ABTestStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum DealStage {
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  FOLLOW_UP
  CALL
  EMAIL
  MEETING
  OTHER
}

model Lead {
  id        String     @id @default(cuid())
  firstName String
  lastName  String?
  email     String
  phone     String?
  status    LeadStatus @default(NEW) //Statusy leadów i pipeline
  score     Int        @default(0) //Lead scoring
  source    String? //Z jakiego lejka/formularza pochodzi
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  ownerId String?
  owner   User?  @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  //Relacje
  tags         Tag[]         @relation("LeadTags")
  customFields CustomField[]
  notes        Note[]
  documents    Document[]
  meetings     Meeting[]
  messages     Message[]
  tasks        Task[]
  deals        Deal[]
  @@index([ownerId])
  @@unique([ownerId, email])
}

model Tag {
  id    String @id @default(cuid())
  name  String
  ownerId String?
  owner   User?  @relation("TagOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  leads Lead[] @relation("LeadTags")

  @@index([ownerId])
  @@unique([ownerId, name])
}

model Note {
  id        String   @id @default(cuid())
  content   String   @db.Text
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model LandingPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique //Do publikowania na domenie
  htmlData  String?  @db.Text //Wygenerowany kod przez GrapesJS
  cssData   String?  @db.Text
  isActive  Boolean  @default(false)
  isPublic  Boolean  @default(false)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants  ABVariant[]
  steps     FunnelStep[]

  @@index([authorId])
}

model Funnel {
  id          String       @id @default(cuid())
  ownerId     String?
  name        String
  slug        String       @unique
  status      FunnelStatus @default(DRAFT)
  description String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  owner       User?        @relation("FunnelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  steps       FunnelStep[]

  @@index([ownerId])
  @@index([status])
}

model FunnelStep {
  id            String         @id @default(cuid())
  funnelId       String
  name           String
  slug           String
  order          Int
  stepType       FunnelStepType @default(LANDING)
  isRequired     Boolean        @default(true)
  landingPageId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  funnel         Funnel         @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  landingPage    LandingPage?   @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  abTests        ABTest[]

  @@unique([funnelId, slug])
  @@unique([funnelId, order])
  @@index([funnelId])
  @@index([landingPageId])
}

model ABTest {
  id            String       @id @default(cuid())
  funnelStepId  String
  name          String
  status        ABTestStatus @default(DRAFT)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  funnelStep    FunnelStep   @relation(fields: [funnelStepId], references: [id], onDelete: Cascade)
  variants      ABVariant[]

  @@index([funnelStepId])
  @@index([status])
}

model ABVariant {
  id            String      @id @default(cuid())
  abTestId      String
  landingPageId String
  name          String
  trafficWeight Int         @default(50)
  views         Int         @default(0)
  conversions   Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  abTest        ABTest      @relation(fields: [abTestId], references: [id], onDelete: Cascade)
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([abTestId])
  @@index([landingPageId])
  @@unique([abTestId, name])
}

//MODUŁ C: KOMUNIKACJA (Email, SMS)

model Message {
  id        String   @id @default(cuid())
  subject   String?
  body      String   @db.Text
  type      String //np. 'EMAIL'
  direction String //'INBOUND' (od leada), 'OUTBOUND' (do leada)
  threadId  String?
  status    String?  @default("OPEN")
  assignedToId String?
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation("MessageAssignee", fields: [assignedToId], references: [id])
  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([assignedToId])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  dueDate     DateTime
  isCompleted Boolean      @default(false)
  priority    TaskPriority @default(MEDIUM)
  type        TaskType     @default(OTHER)
  leadId      String
  userId      String
  dealId      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([userId])
  @@index([dueDate])
  @@index([dealId])
}

model Deal {
  id                String    @id @default(cuid())
  name              String
  value             Float     @default(0)
  currency          String    @default("PLN")
  probability       Int       @default(50)
  expectedCloseDate DateTime?
  stage             DealStage @default(DISCOVERY)
  notes             String?   @db.Text

  leadId  String
  lead    Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([ownerId])
  @@index([stage])
}

model AutomationRule {
  id            String  @id @default(cuid())
  name          String
  isActive      Boolean @default(true)
  triggerType   String
  triggerConfig Json
  actionType    String
  actionConfig  Json

  ownerId String
  owner   User @relation("AutomationOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  logs AutomationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([triggerType])
}

model AutomationLog {
  id           String         @id @default(cuid())
  automationId String
  automation   AutomationRule @relation(fields: [automationId], references: [id], onDelete: Cascade)
  leadId       String?
  dealId       String?
  status       String
  details      String?        @db.Text
  executedAt   DateTime       @default(now())

  @@index([automationId])
}

//MODUŁ D: KURSY I PORTAL CZŁONKOWSKI

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  price       Float?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String?
  author   User?  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  modules     Module[]
  enrollments Enrollment[]
  orders      Order[]

  @@index([authorId])
}

model Order {
  id              String      @id @default(cuid())
  stripeSessionId String      @unique
  amount          Int
  status          OrderStatus @default(PENDING)

  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int // Kolejność modułów
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
}

model Lesson {
  id        String  @id @default(cuid())
  title     String
  videoUrl  String? //Hostowanie wideo
  videoText String? @db.Text // Tekst / transkrypcja do wideo
  content   String? @db.Text
  order     Int
  moduleId  String
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  resources   LessonResource[]
  completions LessonCompletion[]
  notes       StudentLessonNote[]
  questions   LessonQuestion[]
}

model StudentLessonNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([lessonId])
}

enum LessonQuestionType {
  OPEN_TEXT
  MULTIPLE_CHOICE_ABC
}

model LessonQuestion {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question    String   @db.Text
  type        LessonQuestionType @default(OPEN_TEXT)
  answer      String?  @db.Text
  optionA     String?  @db.Text
  optionB     String?  @db.Text
  optionC     String?  @db.Text
  correctOption String?
  order       Int      @default(1)
  createdById String?
  createdBy   User?    @relation("LessonQuestionAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lessonId, order])
}

enum LessonResourceType {
  LINK
  PDF
}

model LessonResource {
  id    String             @id @default(cuid())
  type  LessonResourceType
  title String
  url   String
  order Int                @default(1)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([lessonId, order])
}

model Enrollment {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId          String
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress          Int                @default(0) // Procent ukończenia
  createdAt         DateTime           @default(now())
  lessonCompletions LessonCompletion[]

  @@unique([userId, courseId])
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title    String
  issuedAt DateTime @default(now())
}

model LessonCompletion {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt  DateTime   @default(now())

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

// ======================================================
// MODUŁ E: DOKUMENTY I E-SIGNING
// ======================================================

model Document {
  id        String    @id @default(cuid())
  title     String
  fileUrl   String // Ścieżka do zapisanego pliku PDF/HTML
  isSigned  Boolean   @default(false)
  signature String?   @db.Text // Plik graficzny z react-signature-canvas (base64)
  signedAt  DateTime?

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leadId])
}

// MODUŁ F: KALENDARZ I SPOTKANIA

model Meeting {
  id        String   @id @default(cuid())
  title     String
  startTime DateTime // Format UTC
  endTime   DateTime
  meetLink  String? // Wirtualny pokój, np. Zoom/Meet
  googleEventId  String?
  outlookEventId String?

  organizerId String
  organizer   User   @relation("MeetingOrganizer", fields: [organizerId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])
  reminders MeetingReminder[]

  createdAt DateTime @default(now())

  @@unique([organizerId, startTime])
}

model MeetingReminder {
  id        String   @id @default(cuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  type      String
  sentAt    DateTime @default(now())

  @@index([meetingId, type])
}

model InternalComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  authorId  String
  threadId  String

  author User @relation("InternalCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([authorId])
}

model CustomField {
  id    String @id @default(cuid())
  name  String // np. "Rozmiar firmy", "Budżet", "Branża"
  value String // Wartość pola np. "50-100", "50000 PLN", "IT"

  // Relacja Jeden-do-Wielu (Jeden Lead może mieć wiele własnych pól)
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Zabezpieczenie: Dany Lead nie może mieć dwóch Custom Fieldów o takiej samej nazwie
  @@unique([leadId, name])
}
