generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  KREATOR
  UCZESTNIK
}

model User {
  id                      String    @id @default(cuid())
  name                    String?
  email                   String?   @unique
  password                String? // Pole na zahashowane hasło
  timezone                String?   @default("Europe/Warsaw")
  emailVerified           DateTime?
  image                   String?
  role                    Role      @default(UCZESTNIK)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  jiraSelectedProjectKey  String?
  jiraSelectedProjectName String?
  jiraSelectedCloudId     String?

  accounts           Account[]
  sessions           Session[]
  apiKeyIntegrations ApiKeyIntegration[]

  // Relacje biznesowe
  organizedMeetings Meeting[]     @relation("MeetingOrganizer")
  tasks             Task[]
  enrollments       Enrollment[]
  certificates      Certificate[]
  lessonNotes       StudentLessonNote[]
  lessonQuestionsAuthored LessonQuestion[] @relation("LessonQuestionAuthor")
  landingPages      LandingPage[]
  ownedLeads        Lead[]        @relation("LeadOwner")
  tags             Tag[]         @relation("TagOwner")
  courses           Course[]
  funnels           Funnel[]      @relation("FunnelOwner")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ApiKeyIntegration {
  id           String   @id @default(cuid())
  userId       String
  providerName String
  encryptedKey String   @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerName])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//MODUŁ A & B: CRM, LEADY, LEJKI SPRZEDAŻY

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum FunnelStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FunnelStepType {
  LANDING
  CHECKOUT
  THANK_YOU
  CUSTOM
}

enum ABTestStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Lead {
  id        String     @id @default(cuid())
  firstName String
  lastName  String?
  email     String
  phone     String?
  status    LeadStatus @default(NEW) //Statusy leadów i pipeline
  score     Int        @default(0) //Lead scoring
  source    String? //Z jakiego lejka/formularza pochodzi
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  ownerId String?
  owner   User?  @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  //Relacje
  tags         Tag[]         @relation("LeadTags")
  customFields CustomField[]
  notes        Note[]
  documents    Document[]
  meetings     Meeting[]
  messages     Message[]
  tasks        Task[]
  @@index([ownerId])
  @@unique([ownerId, email])
}

model Tag {
  id    String @id @default(cuid())
  name  String
  ownerId String?
  owner   User?  @relation("TagOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  leads Lead[] @relation("LeadTags")

  @@index([ownerId])
  @@unique([ownerId, name])
}

model Note {
  id        String   @id @default(cuid())
  content   String   @db.Text
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model LandingPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique //Do publikowania na domenie
  htmlData  String?  @db.Text //Wygenerowany kod przez GrapesJS
  cssData   String?  @db.Text
  isActive  Boolean  @default(false)
  isPublic  Boolean  @default(false)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants  ABVariant[]
  steps     FunnelStep[]

  @@index([authorId])
}

model Funnel {
  id          String       @id @default(cuid())
  ownerId     String?
  name        String
  slug        String       @unique
  status      FunnelStatus @default(DRAFT)
  description String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  owner       User?        @relation("FunnelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  steps       FunnelStep[]

  @@index([ownerId])
  @@index([status])
}

model FunnelStep {
  id            String         @id @default(cuid())
  funnelId       String
  name           String
  slug           String
  order          Int
  stepType       FunnelStepType @default(LANDING)
  isRequired     Boolean        @default(true)
  landingPageId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  funnel         Funnel         @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  landingPage    LandingPage?   @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  abTests        ABTest[]

  @@unique([funnelId, slug])
  @@unique([funnelId, order])
  @@index([funnelId])
  @@index([landingPageId])
}

model ABTest {
  id            String       @id @default(cuid())
  funnelStepId  String
  name          String
  status        ABTestStatus @default(DRAFT)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  funnelStep    FunnelStep   @relation(fields: [funnelStepId], references: [id], onDelete: Cascade)
  variants      ABVariant[]

  @@index([funnelStepId])
  @@index([status])
}

model ABVariant {
  id            String      @id @default(cuid())
  abTestId      String
  landingPageId String
  name          String
  trafficWeight Int         @default(50)
  views         Int         @default(0)
  conversions   Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  abTest        ABTest      @relation(fields: [abTestId], references: [id], onDelete: Cascade)
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([abTestId])
  @@index([landingPageId])
  @@unique([abTestId, name])
}

//MODUŁ C: KOMUNIKACJA (Email, SMS)

model Message {
  id        String   @id @default(cuid())
  subject   String?
  body      String   @db.Text
  type      String //np. 'EMAIL'
  direction String //'INBOUND' (od leada), 'OUTBOUND' (do leada)
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  leadId      String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([userId])
  @@index([dueDate])
}

//MODUŁ D: KURSY I PORTAL CZŁONKOWSKI

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  price       Float?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String?
  author   User?  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  modules     Module[]
  enrollments Enrollment[]

  @@index([authorId])
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int // Kolejność modułów
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
}

model Lesson {
  id        String  @id @default(cuid())
  title     String
  videoUrl  String? //Hostowanie wideo
  videoText String? @db.Text // Tekst / transkrypcja do wideo
  content   String? @db.Text
  order     Int
  moduleId  String
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  resources   LessonResource[]
  completions LessonCompletion[]
  notes       StudentLessonNote[]
  questions   LessonQuestion[]
}

model StudentLessonNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model LessonQuestion {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question    String   @db.Text
  answer      String?  @db.Text
  order       Int      @default(1)
  createdById String?
  createdBy   User?    @relation("LessonQuestionAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lessonId, order])
}

enum LessonResourceType {
  LINK
  PDF
}

model LessonResource {
  id    String             @id @default(cuid())
  type  LessonResourceType
  title String
  url   String
  order Int                @default(1)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([lessonId, order])
}

model Enrollment {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId          String
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress          Int                @default(0) // Procent ukończenia
  createdAt         DateTime           @default(now())
  lessonCompletions LessonCompletion[]

  @@unique([userId, courseId])
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title    String
  issuedAt DateTime @default(now())
}

model LessonCompletion {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt  DateTime   @default(now())

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

// ======================================================
// MODUŁ E: DOKUMENTY I E-SIGNING
// ======================================================

model Document {
  id        String    @id @default(cuid())
  title     String
  fileUrl   String // Ścieżka do zapisanego pliku PDF/HTML
  isSigned  Boolean   @default(false)
  signature String?   @db.Text // Plik graficzny z react-signature-canvas (base64)
  signedAt  DateTime?

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leadId])
}

// MODUŁ F: KALENDARZ I SPOTKANIA

model Meeting {
  id        String   @id @default(cuid())
  title     String
  startTime DateTime // Format UTC
  endTime   DateTime
  meetLink  String? // Wirtualny pokój, np. Zoom/Meet

  organizerId String
  organizer   User   @relation("MeetingOrganizer", fields: [organizerId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())

  @@unique([organizerId, startTime])
}

model CustomField {
  id    String @id @default(cuid())
  name  String // np. "Rozmiar firmy", "Budżet", "Branża"
  value String // Wartość pola np. "50-100", "50000 PLN", "IT"

  // Relacja Jeden-do-Wielu (Jeden Lead może mieć wiele własnych pól)
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Zabezpieczenie: Dany Lead nie może mieć dwóch Custom Fieldów o takiej samej nazwie
  @@unique([leadId, name])
}
